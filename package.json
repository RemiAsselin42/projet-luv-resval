{
  "name": "projet-luv-resval",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS= vite",
    "build": "cross-env NODE_OPTIONS= vite build",
    "preview": "cross-env NODE_OPTIONS= vite preview",
    "lf:check": "node scripts/check-lf.mjs",
    "lf:fix": "node scripts/fix-lf.mjs",
    "format:check": "npm run lint && npm run lint:style",
    "lint": "cross-env NODE_OPTIONS= eslint \"src/**/*.{js,ts,tsx}\" --max-warnings 0",
    "lint:fix": "cross-env NODE_OPTIONS= eslint \"src/**/*.{js,ts,tsx}\" --fix",
    "lint:style": "cross-env NODE_OPTIONS= stylelint \"src/**/*.{css,scss}\"",
    "lint:style:fix": "cross-env NODE_OPTIONS= stylelint \"src/**/*.{css,scss}\" --fix",
    "typecheck": "cross-env NODE_OPTIONS= tsc --noEmit",
    "test": "cross-env NODE_OPTIONS= vitest run",
    "validate": "npm run lf:check && npm run lint && npm run lint:style && npm run typecheck && npm run build"
  },
  "dependencies": {
    "gsap": "^3.14.2",
    "howler": "^2.2.4",
    "lenis": "^1.3.13",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/howler": "^2.2.12",
    "@types/node": "^25.3.3",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "globals": "^14.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.35",
    "postcss-html": "^1.6.0",
    "sass": "^1.70.0",
    "stylelint": "^16.2.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.1.0",
    "vitest": "^2.1.8"
  }
}
